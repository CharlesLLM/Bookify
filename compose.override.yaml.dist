services:
  db:
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "admin", "-d", "bookify"]
      interval: 5s
      timeout: 5s
      retries: 5

  pgweb:
    image: sosedoff/pgweb
    restart: always
    depends_on:
      db:
        condition: service_healthy
    ports:
      - 8081:8081
    environment:
      PGWEB_DATABASE_URL: ${PGWEB_DATABASE_URL}
